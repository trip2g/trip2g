$trip2g_editor_preview $mol_view
	preview_html \
	sub /
		<= Head $mol_view
			sub / <= head_title @ \Preview
		<= Body $mol_view
			dom_name \article
			style *
				justifyContent \center
				alignItems \center
				minHeight \500px
			sub /
				<= WIP $mol_view
					sub / \WORK IN PROGRESS
				<= preview_html
