$trip2g_admin_telegramcustomemojies $mol_page
	title @ \Telegram Custom Emojies
	body /
		<= List $mol_list
			rows <= rows /$mol_view
				<= Row*0 $mol_row
					sub /
						<= Img* $mol_view
							dom_name \img
							attr *
								width \32px
								height \32px
								src <= row_src* \src
						<= Label* $mol_string
							value <= row_label* \name

