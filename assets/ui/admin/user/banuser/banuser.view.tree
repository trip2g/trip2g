$trip2g_admin_user_banuser $mol_page
	user_id 0
	title \Ban
	body /
		<= Form $mol_form
			body /
				<= Reason_field $mol_form_field
					name \Reason
					bid <= reason_bid \
					Content <= reason_control $mol_string
						hint \Enter reason for ban
						value? <=> reason? \
			buttons /
				<= Submit $mol_button_major
					title \Submit
					click? <=> submit? null
				<= Result $mol_status
					message <= result? \
