$trip2g_user_paywall $mol_view
	subgraphs /string
	minimal_height 0
	minimal_width 0
	plugins /
		<= Theme $mol_theme_auto
	sub /
		\Эта страница доступна только для подписчиков.
		<= Message $mol_view
			sub / <= message \
		<= PurchaseItems $trip2g_user_paywall_activepurchases
			subgraphs <= subgraphs
		<= Offers $trip2g_user_paywall_offers
			subgraphs <= subgraphs
