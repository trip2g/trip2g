http:
  routers:
{% for svc in trip2g_services %}
    {{ svc.service_name }}:
      rule: "Host(`{{ svc.domain }}`)"
      entryPoints:
        - websecure
      service: {{ svc.service_name }}
      tls:
        certResolver: letsencrypt
{% if svc.extra_domains is defined %}
{% for extra in svc.extra_domains %}
    {{ svc.service_name }}_extra_{{ loop.index }}:
      rule: "Host(`{{ extra }}`)"
      entryPoints:
        - websecure
      service: {{ svc.service_name }}
      tls:
        certResolver: letsencrypt
{% endfor %}
{% endif %}
{% endfor %}
    lottie-converter:
      rule: "Host(`{{ lottie_domain | default('ce.trip2g.com') }}`)"
      entryPoints:
        - websecure
      service: lottie-converter
      tls:
        certResolver: letsencrypt

  services:
{% for svc in trip2g_services %}
    {{ svc.service_name }}:
      loadBalancer:
        servers:
          - url: "http://{{ svc.listen_addr }}"
{% endfor %}
    lottie-converter:
      loadBalancer:
        servers:
          - url: "http://localhost:{{ lottie_port | default('3000') }}"
