[Unit]
Description=trip2g service
After=network.target

[Service]
User=trip2g
Group=trip2g

WorkingDirectory=/opt/trip2g/data
ExecStart=/opt/trip2g/bin/app --listen-addr {{ item.listen_addr }}
EnvironmentFile=/etc/{{ item.service_name }}.env
Restart=on-failure
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
AmbientCapabilities=CAP_NET_BIND_SERVICE

# NoNewPrivileges=true
# PrivateTmp=true
