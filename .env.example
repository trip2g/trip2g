# Example .env file for trip2g server
# Copy this to .env and modify values as needed

# Server configuration
LISTEN_ADDR=:8081
DB_FILE=data.sqlite3
LOG_LEVEL=info
DEV=false
ADMIN_JS_URL=/assets/ui/admin/-/web.js

# Application URLs and keys
PUBLIC_URL=https://yourdomain.com
NOWPAYMENTS_API_KEY=your_nowpayments_api_key_here
NOWPAYMENTS_IPN_KEY=your_nowpayments_ipn_key_here

# MinIO storage configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY_ID=root
MINIO_SECRET_KEY=password
MINIO_BUCKET=development
MINIO_REGION=us-east-1
MINIO_USE_SSL=false
MINIO_INIT_TIMEOUT=5s
MINIO_URL_EXPIRES_IN=10m

# ACME/TLS configuration (multiple domains can be specified via command line flags)
# ACME_DOMAIN=example.com

# for dbmate
DATABASE_URL=sqlite:data.sqlite3
