$trip2g_auth $mol_view
	EmailForm $trip2g_auth_email_form
	CodeForm $trip2g_auth_code_form
		reload_me <= reload_me null
	AppView $trip2g_admin
		profile_info <= ProfileInfo $mol_button_major
			title <= me_user_email? \???
		sign_out <= SignOut $mol_button_major
			click? <=> signout? null
	sub / <= EmailForm

$trip2g_auth_email_form $mol_form
	body /
		<= Email_field $mol_form_field
			name \Email
			bid <= email_bid \
			Content <= email_control $mol_string
				hint \name@example.com
				value? <=> email? \hello@example.com
	buttons /
		<= RequestCode $mol_button_major
			dom_name \button
			title \Enter
			click? <=> submit? null
		<= RequestResult $mol_status
			message <= result? \

$trip2g_auth_code_form $mol_form
	reload_me null
	body /
		<= Code_field $mol_form_field
			name \Code
			bid <= code_bid \
			Content <= code_control $mol_string
				hint \000000
				value? <=> code? \111111
	buttons /
		<= Signup $mol_button_major
			title \Enter
			click? <=> submit? null
		<= Result $mol_status
			message <= result? \
