$trip2g_user_space $mol_view
	sub /
		\Profile...
		<= Open $mol_button_major
			click <= open null
		<= Dialog $mol_view
			dom_name \dialog
			attr * open <= open_status null null|string
			sub /
				<= AuthWrapper $trip2g_auth
					signout => signout
					AppView <= Content
	Content $mol_view
		sub /
			\Content...
			<= Email $mol_view
				sub / <= user_email \
			<= Close $mol_button_minor
				click <= close null
			<= SignOut $mol_button_major
				click? <=> signout
