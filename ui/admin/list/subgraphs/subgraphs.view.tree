$trip2g_admin_list_subgraphs $mol_book2_catalog
	row_id_number* 0
	update_marker? 0
	menu_title \Subgraphs
	menu_tools / <= Spread_close
	menu_filter_enabled true
	param \subgraph_id
	Empty $mol_status
	Content* $trip2g_admin_show_subgraph
		subgraph_id <= row_id_number*
		on_save? <=> update_marker?
		tools / <= Spread_close
	menu_link_content* / <= NoteItem* $mol_view
		sub /
			<= Rows* $mol_row
				minimal_height 24
				minimal_width 400
				sub <= row_content* /
					<= Row_id_labeler* $mol_labeler
						title \ID
						Content <= Row_id* $trip2g_admin_cell
							content <= row_id* \id
					<= Row_name_labeler* $mol_labeler
						title \Name
						Content <= Row_name* $trip2g_admin_cell
							content <= row_name* \name
					<= Row_color_labeler* $mol_labeler
						title \Color
						Content <= Row_color* $trip2g_admin_cell
							content <= row_color* \color
