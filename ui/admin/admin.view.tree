$trip2g_admin $mol_book2_catalog
	param \nav
	menu_title \Admin
	menu_foot /
		<= profile_info $mol_button_major
			title \hello@example.com
		<= sign_out $mol_button_major
			title \Sign out
	spreads *
		listusers <= ListUsers $trip2g_admin_pages_listusers
		listusersubgraphaccesses <= ListUsersSubgraphAccesses $trip2g_admin_pages_listusersubgraphaccesses

$trip2g_admin_cell $mol_view
	content \No Content
	sub /
		<= content
