$trip2g_admin_show_usersubgraphaccess $mol_page
	access_id 0
	minimal_width 400
	body /
		<= Form $mol_form
			body /
				<= ExpiresAt_field $mol_form_field
					name \Expires At
					bid <= expires_at_bid \
					Content <= expires_at_control $mol_date
						value_moment? <=> expires_at_moment? null
			buttons /
				<= Submit $mol_button_major
					title \Submit
					click? <=> submit? null
				<= Result $mol_status
					message <= result? \

