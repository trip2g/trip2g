#
# pushNotes
#

input PushNoteInput {
  path: String!
  content: String!
}

input PushNotesInput @goExtraField(name: "ApiKey", type: "trip2g/internal/db.ApiKey") @goExtraField(name: "Partial", type: "bool") {
  skipCommit: Boolean
  updates: [PushNoteInput!]!
}

type PushedNoteAsset {
  id: String! # relative path (e.g., "./assets/image.jpg")
  assetId: Int64! # numeric ID from database
  path: String! # the client must resolve this to the absolute path
  sha256Hash: String # if the hash does not match
  absolutePath: String! # vault path (e.g., "/subdir/assets/image.jpg")
  url: String! # presigned S3 URL
}

type PushedNote {
  id: Int64!
  path: String!
  assets: [PushedNoteAsset!]!
}

type PushNotesPayload {
  notes: [PushedNote!]!
}

union PushNotesOrErrorPayload = PushNotesPayload | ErrorPayload

#
# uploadNoteAsset
#

input UploadNoteAssetInput @goExtraField(name: "ApiKey", type: "trip2g/internal/db.ApiKey") @goExtraField(name: "Partial", type: "bool") @goExtraField(name: "SkipPrepare", type: "bool") {
  skipCommit: Boolean
  file: Upload!
  noteId: Int64! # TODO: change to noteVersionId
  sha256Hash: String! # must be calculated by the client, the request will be reqected if the hash does not match after upload
  path: String! # the path from the note markdown
  absolutePath: String!
}

type UploadNoteAssetPayload {
  uploadSkipped: Boolean!
}

union UploadNoteAssetOrErrorPayload = UploadNoteAssetPayload | ErrorPayload

