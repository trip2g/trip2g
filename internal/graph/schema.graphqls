# hideNotes
#

input HideNotesInput @goExtraField(name: "ApiKey", type: "trip2g/internal/db.ApiKey") {
  paths: [String!]!
}

type HideNotesPayload {
  success: Boolean!
}

union HideNotesOrErrorPayload = HideNotesPayload | ErrorPayload

#
# createEmailWaitListRequest
#

input CreateEmailWaitListRequestInput {
  email: String!
  pathId: Int64!
}

type CreateEmailWaitListRequestPayload {
  success: Boolean!
}

union CreateEmailWaitListRequestOrErrorPayload = CreateEmailWaitListRequestPayload | ErrorPayload

type Mutation {
  requestEmailSignInCode(input: RequestEmailSignInCodeInput!): RequestEmailSignInCodeOrErrorPayload!
  signInByEmail(input: SignInByEmailInput!): SignInOrErrorPayload!
  signOut: SignOutOrErrorPayload!
  createPaymentLink(input: CreatePaymentLinkInput!): CreatePaymentLinkOrErrorPayload!

  createEmailWaitListRequest(input: CreateEmailWaitListRequestInput!): CreateEmailWaitListRequestOrErrorPayload!

  pushNotes(input: PushNotesInput!): PushNotesOrErrorPayload!
  hideNotes(input: HideNotesInput!): HideNotesOrErrorPayload!
  uploadNoteAsset(input: UploadNoteAssetInput!): UploadNoteAssetOrErrorPayload!

  admin: AdminMutation!
}

