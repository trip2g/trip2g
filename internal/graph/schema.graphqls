type AdminPatreonCredentials @goModel(model: "trip2g/internal/db.PatreonCredential") {
  id: Int64!
  createdAt: Time!
  createdBy: AdminUser! @goField(forceResolver: true)
  deletedAt: Time
  deletedBy: AdminUser @goField(forceResolver: true)
  syncedAt: Time
  creatorAccessToken: String! @goField(forceResolver: true)
  state: PatreonCredentialsStateEnum!
}

type AdminPatreonCredentialsConnection @goExtraField(name: "Filter", type: "*trip2g/internal/graph/model.AdminPatreonCredentialsFilterInput"){
  nodes: [AdminPatreonCredentials!]! @goField(forceResolver: true)
}

input AdminTgBotChatsFilterInput {
  botId: Int64
  includeRemoved: Boolean # defaults to false
}

input AdminTgChatMembersFilterInput {
  chatId: Int64!
}

input AdminTgChatSubgraphAccessesFilterInput {
  chatId: Int64
  subgraphId: Int64
}

enum PatreonCredentialsStateEnum {
  ACTIVE
  DELETED
}

input AdminPatreonCredentialsFilterInput {
  state: PatreonCredentialsStateEnum
}

enum NoteWarningLevelEnum {
  INFO
  WARNING
  CRITICAL
}

input AdminLatestNoteViewsFilter {
  withWarnings: Boolean
}

type AdminQuery {
  allUsers: AdminUsersConnection!
  allSubgraphs: AdminSubgraphsConnection!
  allUserSubgraphAccesses: AdminUserSubgraphAccessesConnection!
  allLatestNoteViews(filter: AdminLatestNoteViewsFilter): AdminLatestNoteViewsConnection!
  allUserUserBans: AdminUserBansConnection!
  allApiKeys: AdminApiKeysConnection!
  allReleases: AdminReleasesConnection!
  allAdmins: AdminAdminsConnection!
  allOffers: AdminOffersConnection!
  allPurchases: AdminPurchasesConnection!
  allRedirects: AdminRedirectsConnection!
  allNotFoundPaths: AdminNotFoundPathsConnection!
  allNotFoundIgnoredPatterns: AdminNotFoundIgnoredPatternsConnection!

  allTgBots: AdminTgBotsConnection!
  tgBotChats(filter: AdminTgBotChatsFilterInput!): AdminTgBotChatsConnection!
  tgChatSubgraphAccesses(filter: AdminTgChatSubgraphAccessesFilterInput!): AdminTgChatSubgraphAccessesConnection!
  tgChatMembers(filter: AdminTgChatMembersFilterInput!): AdminTgChatMembersConnection!

  allPatreonCredentials(filter: AdminPatreonCredentialsFilterInput): AdminPatreonCredentialsConnection!
  patreonCredentials(id: Int64!): AdminPatreonCredentials

  apiKeyLogs(filter: ApiKeyLogsFilterInput!): AdminApiKeyLogsConnection!

  subgraph(id: Int64!): AdminSubgraph
  noteView(id: String!): NoteView
  userSubgraphAccess(id: Int64!): AdminUserSubgraphAccess
  offer(id: Int64!): AdminOffer
  purchase(id: String!): AdminPurchase
  redirect(id: Int64!): AdminRedirect
  tgBot(id: Int64!): AdminTgBot
}

enum Role {
  GUEST
  USER
  ADMIN
}

type ActiveOffers {
  nodes: [Offer!]!
}

type SubgraphWaitList {
  tgBotUrl: String
  emailAllowed: Boolean!
}

union ViewerOffers = ActiveOffers | SubgraphWaitList

input ViewerOffersFilter {
  pageId: Int64
}

type Viewer {
  id: ID!
  role: Role!
  user: User
  offers(filter: ViewerOffersFilter!): ViewerOffers
  activePurchases: [Purchase!]!
}

type Offer {
  id: String!
  priceUSD: Float!

  subgraphs: [Subgraph!]!
}

type Subgraph {
  name: String!
  offers: [Offer!]!
  homePath: String!
}

type Purchase {
  id: String!
  status: String!
  successful: Boolean!
}

type NotePath @goModel(model: "trip2g/internal/model.NotePath"){
  value: String!
  latestContentHash: String!
}

input NoteInput {
  path: String!
  referer: String!
}

type NoteTocItem {
  id: String!
  title: String!
  level: Int!
}

type PublicNote {
  title: String!
  html: String!

  toc: [NoteTocItem!]!
}

type Query {
  viewer: Viewer!
  notePaths: [NotePath!]!
  admin: AdminQuery!
  note(input: NoteInput!): PublicNote
}

type FieldMessage {
  name: String!
  value: String!
}

type ErrorPayload {
  message: String! @goField(forceResolver: true)
  byFields: [FieldMessage!]!
}

#
# requestEmailSignInCode
#

input RequestEmailSignInCodeInput {
  email: String!
}

type RequestEmailSignInCodePayload {
  success: Boolean!
}

union RequestEmailSignInCodeOrErrorPayload = RequestEmailSignInCodePayload | ErrorPayload

#
# signInByEmail
#

input SignInByEmailInput {
  email: String!
  code: String!
}

type SignInPayload {
  token: String!
