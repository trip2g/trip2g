  createdAt: Time!
  homeNoteVersionId: Int64
  createdBy: AdminUser!
  title: String!
  homeNote: NoteView @goField(forceResolver: true)
  isLive: Boolean!
}

type AdminReleasesConnection {
  nodes: [AdminRelease!]! @goField(forceResolver: true)
}

type AdminAdminsConnection {
  nodes: [Admin!]! @goField(forceResolver: true)
}

type AdminOffer @goModel(model: "trip2g/internal/db.Offer") {
