# ============================================
# Telegram Accounts
# ============================================

type AdminTelegramAccount @goModel(model: "trip2g/internal/db.TelegramAccount") {
  id: Int64!
  phone: String!
  displayName: String!
  isPremium: Boolean!
  enabled: Boolean!
  createdAt: Time!
  createdBy: User @goField(forceResolver: true)
  dialogs: [AdminTelegramAccountDialog!]! @goField(forceResolver: true)
}

type AdminTelegramAccountDialog @goModel(model: "trip2g/internal/model.TelegramAccountDialog") {
  id: Int64!
  username: String!
  title: String!
  type: AdminTelegramAccountDialogType!
  publishTags: [AdminTelegramPublishTag!]! @goField(forceResolver: true)
  publishInstantTags: [AdminTelegramPublishTag!]! @goField(forceResolver: true)
}

enum AdminTelegramAccountDialogType {
  user
  channel
  chat
}

type AdminTelegramAccountsConnection {
  nodes: [AdminTelegramAccount!]! @goField(forceResolver: true)
}

type AdminTelegramAccountAuthState {
  phone: String!
  state: AdminTelegramAccountAuthStateEnum!
  passwordHint: String
}

enum AdminTelegramAccountAuthStateEnum {
  WAITING_FOR_CODE
  WAITING_FOR_PASSWORD
  AUTHORIZED
  ERROR
}

#
# startTelegramAccountAuth
#

input AdminStartTelegramAccountAuthInput {
  phone: String!
  apiId: Int!
  apiHash: String!
}

type AdminStartTelegramAccountAuthPayload {
  authState: AdminTelegramAccountAuthState!
}

union AdminStartTelegramAccountAuthOrErrorPayload = AdminStartTelegramAccountAuthPayload | ErrorPayload

#
# completeTelegramAccountAuth
#

input AdminCompleteTelegramAccountAuthInput {
  phone: String!
  code: String!
  password: String
}

type AdminCompleteTelegramAccountAuthPayload {
  account: AdminTelegramAccount!
}

union AdminCompleteTelegramAccountAuthOrErrorPayload = AdminCompleteTelegramAccountAuthPayload | ErrorPayload

#
# cancelTelegramAccountAuth
#

input AdminCancelTelegramAccountAuthInput {
  phone: String!
}

type AdminCancelTelegramAccountAuthPayload {
  success: Boolean!
}

union AdminCancelTelegramAccountAuthOrErrorPayload = AdminCancelTelegramAccountAuthPayload | ErrorPayload

#
# updateTelegramAccount
#

input AdminUpdateTelegramAccountInput {
  id: Int64!
  displayName: String
  enabled: Boolean
}

type AdminUpdateTelegramAccountPayload {
  account: AdminTelegramAccount!
}

union AdminUpdateTelegramAccountOrErrorPayload = AdminUpdateTelegramAccountPayload | ErrorPayload

#
# signOutTelegramAccount
#

input AdminSignOutTelegramAccountInput {
  id: Int64!
}

type AdminSignOutTelegramAccountPayload {
  success: Boolean!
}

union AdminSignOutTelegramAccountOrErrorPayload = AdminSignOutTelegramAccountPayload | ErrorPayload

#
# setTelegramAccountChatPublishTags
#

input AdminSetTelegramAccountChatPublishTagsInput {
  accountId: Int64!
  telegramChatId: String!
  tagIds: [Int64!]!
}

type AdminSetTelegramAccountChatPublishTagsPayload {
  success: Boolean!
}

union AdminSetTelegramAccountChatPublishTagsOrErrorPayload = AdminSetTelegramAccountChatPublishTagsPayload | ErrorPayload

#
# setTelegramAccountChatPublishInstantTags
#

input AdminSetTelegramAccountChatPublishInstantTagsInput {
  accountId: Int64!
  telegramChatId: String!
  tagIds: [Int64!]!
}

type AdminSetTelegramAccountChatPublishInstantTagsPayload {
  success: Boolean!
}

union AdminSetTelegramAccountChatPublishInstantTagsOrErrorPayload = AdminSetTelegramAccountChatPublishInstantTagsPayload | ErrorPayload

#
# importTelegramAccountChannel
#

input AdminImportTelegramAccountChannelInput {
  accountId: Int64!
  channelId: Int64!
  basePath: String!
  # Download and import media (photos/videos). Default: false
  withMedia: Boolean
  # Skip posts that already exist in notes. Default: true
  skipExists: Boolean
}

type AdminImportTelegramAccountChannelPayload {
  success: Boolean!
}

union AdminImportTelegramAccountChannelOrErrorPayload = AdminImportTelegramAccountChannelPayload | ErrorPayload

type AdminQuery {
  allUsers: AdminUsersConnection!
  allSubgraphs: AdminSubgraphsConnection!
  allUserSubgraphAccesses: AdminUserSubgraphAccessesConnection!
  allLatestNoteViews(filter: AdminLatestNoteViewsFilter): AdminLatestNoteViewsConnection!
  recentlyModifiedNoteViews: [NoteView!]!
  allUserUserBans: AdminUserBansConnection!
  allApiKeys: AdminApiKeysConnection!
  allGitTokens: AdminGitTokensConnection!
  allReleases: AdminReleasesConnection!
  allAdmins: AdminAdminsConnection!
  allOffers: AdminOffersConnection!
  allPurchases: AdminPurchasesConnection!
  allRedirects: AdminRedirectsConnection!
  allNotFoundPaths: AdminNotFoundPathsConnection!
  allNotFoundIgnoredPatterns: AdminNotFoundIgnoredPatternsConnection!
  allLatestNoteAssets: AdminLatestNoteAssetsConnection!
  allHtmlInjections: AdminHtmlInjectionsConnection!
  allCronJobs: AdminCronJobsConnection!
  allConfigVersions: AdminConfigVersionsConnection!
  allTelegramPublishTags: AdminTelegramPublishTagsConnection!
  allTelegramPublishNotes(filter: AdminTelegramPublishNotesFilter): AdminTelegramPublishNotesConnection!

  allTelegramAccounts: AdminTelegramAccountsConnection!
  telegramAccount(id: Int64!): AdminTelegramAccount

  allWaitListEmailRequests: AdminWaitListEmailRequestsConnection!
  allWaitListTgBotRequests: AdminWaitListTgBotRequestsConnection!

  allTgBots: AdminTgBotsConnection!
  tgBotChats(filter: AdminTgBotChatsFilterInput!): AdminTgBotChatsConnection!
  tgChatSubgraphAccesses(filter: AdminTgChatSubgraphAccessesFilterInput!): AdminTgChatSubgraphAccessesConnection!
  tgChatMembers(filter: AdminTgChatMembersFilterInput!): AdminTgChatMembersConnection!

  allPatreonCredentials(filter: AdminPatreonCredentialsFilterInput): AdminPatreonCredentialsConnection!
  patreonCredentials(id: Int64!): AdminPatreonCredentials

  allBoostyCredentials(filter: AdminBoostyCredentialsFilterInput): AdminBoostyCredentialsConnection!
  boostyCredentials(id: Int64!): AdminBoostyCredentials

  apiKeyLogs(filter: ApiKeyLogsFilterInput!): AdminApiKeyLogsConnection!
  auditLogs(filter: AdminAuditLogsFilterInput!): AdminAuditLogsConnection!

  latestConfig: AdminConfigVersion!

  subgraph(id: Int64!): AdminSubgraph
  noteView(id: String!): NoteView
  userSubgraphAccess(id: Int64!): AdminUserSubgraphAccess
  offer(id: Int64!): AdminOffer
  user(id: Int64!): AdminUser
  purchase(id: String!): AdminPurchase
  redirect(id: Int64!): AdminRedirect
  tgBot(id: Int64!): AdminTgBot
  noteAsset(id: Int64!): AdminNoteAsset
  htmlInjection(id: Int64!): AdminHtmlInjection
  cronJob(id: Int64!): AdminCronJob
  telegramPublishNote(id: Int64!): AdminTelegramPublishNote

  activeUserSubgraphs(id: Int64!): [String!]!

  allBackgroundQueues: AdminBackgroundQueuesConnection!
  backgroundQueue(id: String!): AdminBackgroundQueue

  healthChecks: [HealchCheck!]!
  buildGitCommit: String!

  # Layout blocks for visual editor autocomplete
  layoutBlocks: [LayoutBlock!]!
}

# Block definition from Jet templates
type LayoutBlock {
  name: String!           # "header", "card"
  fullName: String!       # "blocks.html#header"
  sourceId: String!       # "blocks.html"
  hasContent: Boolean!    # true if block uses {{ yield content }}
  params: [LayoutBlockParam!]!
}

# Block parameter metadata
type LayoutBlockParam {
  name: String!
  value: LayoutBlockParamValue    # typed default value, null if unknown type
  comment: String                 # human-readable description from arg_type
}

union LayoutBlockParamValue = StringParamValue | IntParamValue | FloatParamValue | BoolParamValue

type StringParamValue {
  defaultValue: String
}

type IntParamValue {
  defaultValue: Int
}

type FloatParamValue {
  defaultValue: Float
}

type BoolParamValue {
  defaultValue: Boolean
}

enum HealthCheckStatus {
  OK
  WARNING
  CRITICAL
}

type HealchCheck {
  id: String!
  status: HealthCheckStatus!
  description: String!
}

enum Role {
  GUEST
  USER
  ADMIN
}

enum CronJobExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

type ActiveOffers {
  nodes: [Offer!]!
}

type SubgraphWaitList {
  tgBotUrl: String
  emailAllowed: Boolean!
}

union ViewerOffers = ActiveOffers | SubgraphWaitList

input ViewerOffersFilter {
  pageId: Int64
}

input LastNoteReadAtInput {
  pathId: Int64!
}

type TgBot {
  id: Int64!
  description: String!
}

type Viewer {
  id: ID!
  role: Role!
  user: User
  offers(filter: ViewerOffersFilter!): ViewerOffers
  activePurchases: [Purchase!]!
  lastNoteReadAt(input: LastNoteReadAtInput!): Time
  tgBots: [TgBot!]!
}

type Offer {
  id: String!
  priceUSD: Float!

  subgraphs: [Subgraph!]!
}

type Subgraph {
  name: String!
  offers: [Offer!]!
  homePath: String!
}

type Purchase {
  id: String!
  status: String!
  successful: Boolean!
}

type NotePath @goModel(model: "trip2g/internal/model.NotePath"){
  value: String!
  latestContentHash: String!
  latestNoteView: NoteView
  content: String!
  assetReplaces: [NoteAssetReplaceT!]!
}

input NoteInput {
  path: String
  pathId: Int64
  referer: String!
}

type NoteTocItem {
  id: String!
  title: String!
  level: Int!
}

type PublicNote @goExtraField(name: "NoteView", type: "*trip2g/internal/model.NoteView") {
  pathId: Int64!
  path: String!
  url: String! @goField(forceResolver: true)
  title: String!
  html: String!

  toc: [NoteTocItem!]!
}

union SearchResultDocument = PublicNote

input SearchInput {
  query: String!
}

type SearchResult {
  highlightedTitle: String
  highlightedContent: [String!]!
  url: String!

  document: SearchResultDocument
}

type SearchConnection @goExtraField(name: "Input", type: "*trip2g/internal/graph/model.SearchInput"){
  totalCount: Int64!
  nodes: [SearchResult!]!
}

input NotePathsFilter {
  """
  LIKE pattern with % and _ wildcards supported.
  For example, to find all note paths starting with "myfolder/", use "myfolder/%".
  """
  like: String # LIKE pattern with % and _ wildcards supported.

  """
  Full-text search on note paths. like will be ignored if search is set.
  """
  search: String

  """
  Only return these specific note paths. Search and like will be ignored if paths is set.
  """
  paths: [String!]
}

input SimilarNotesInput {
  """
  Note path (permalink) to find similar notes for.
  """
  path: String!

  """
  Maximum number of similar notes to return (default: 5, max: 20).
  """
  limit: Int
}

type SimilarNote {
  """
  Similarity score (0-1, higher is more similar).
  """
  score: Float!
  note: PublicNote!
}

type Query {
  viewer: Viewer!
  admin: AdminQuery!
  note(input: NoteInput!): PublicNote
  search(input: SearchInput!): SearchConnection!

  """
  Find notes semantically similar to the given note using vector embeddings.
  Returns empty list if vector search is disabled or note has no embedding.
  """
  similarNotes(input: SimilarNotesInput!): [SimilarNote!]!

  """
  X-Api-Key header must be set.
  """
  notePaths(filter: NotePathsFilter): [NotePath!]!
}

type FieldMessage {
  name: String!
  value: String!
}

type ErrorPayload {
  message: String! @goField(forceResolver: true)
  byFields: [FieldMessage!]!
}

