#
# generateTgAttachCode
#

input GenerateTgAttachCodeInput {
  botId: Int64!
}

type GenerateTgAttachCodePayload {
  code: String!
  url: String!
}

union GenerateTgAttachCodeOrErrorPayload = GenerateTgAttachCodePayload | ErrorPayload

type CommitNotesPayload {
  success: Boolean!
}

union CommitNotesOrErrorPayload = CommitNotesPayload | ErrorPayload

type Mutation {
  requestEmailSignInCode(input: RequestEmailSignInCodeInput!): RequestEmailSignInCodeOrErrorPayload!
  signInByEmail(input: SignInByEmailInput!): SignInOrErrorPayload!
  signOut: SignOutOrErrorPayload!
  createPaymentLink(input: CreatePaymentLinkInput!): CreatePaymentLinkOrErrorPayload!

  createEmailWaitListRequest(input: CreateEmailWaitListRequestInput!): CreateEmailWaitListRequestOrErrorPayload!

  toggleFavoriteNote(input: ToggleFavoriteNoteInput!): ToggleFavoriteNoteOrErrorPayload!

  """
  X-Api-Key header must be set.
  """
  pushNotes(input: PushNotesInput!): PushNotesOrErrorPayload!

  """
  X-Api-Key header must be set.
  """
  hideNotes(input: HideNotesInput!): HideNotesOrErrorPayload!

  """
  X-Api-Key header must be set.
  """
  uploadNoteAsset(input: UploadNoteAssetInput!): UploadNoteAssetOrErrorPayload! @skipTx

  """
  X-Api-Key header must be set.
  """
  commitNotes: CommitNotesOrErrorPayload!

  generateTgAttachCode(input: GenerateTgAttachCodeInput!): GenerateTgAttachCodeOrErrorPayload!

  admin: AdminMutation!
}

