type AdminMutation {
  updateSubgraph(input: UpdateSubgraphInput!): UpdateSubgraphOrErrorPayload!
  updateUserSubgraphAccess(input: UpdateUserSubgraphAccessInput!): UpdateUserSubgraphAccessOrErrorPayload!

  createOffer(input: CreateOfferInput!): CreateOfferOrErrorPayload!
  updateOffer(input: UpdateOfferInput!): UpdateOfferOrErrorPayload!

  resetNotFoundPath(input: ResetNotFoundPathInput!): ResetNotFoundPathOrErrorPayload!
  createNotFoundIgnoredPattern(input: CreateNotFoundIgnoredPatternInput!): CreateNotFoundIgnoredPatternOrErrorPayload!
  updateNotFoundIgnoredPattern(input: UpdateNotFoundIgnoredPatternInput!): UpdateNotFoundIgnoredPatternOrErrorPayload!
  deleteNotFoundIgnoredPattern(input: DeleteNotFoundIgnoredPatternInput!): DeleteNotFoundIgnoredPatternOrErrorPayload!

  createRedirect(input: CreateRedirectInput!): CreateRedirectOrErrorPayload!
  updateRedirect(input: UpdateRedirectInput!): UpdateRedirectOrErrorPayload!
  deleteRedirect(input: DeleteRedirectInput!): DeleteRedirectOrErrorPayload!

  unbanUser(input: UnbanUserInput!): UnbanUserOrErrorPayload!
  banUser(input: BanUserInput!): BanUserOrErrorPayload!

  createApiKey(input: CreateApiKeyInput!): CreateApiKeyOrErrorPayload!
  disableApiKey(input: DisableApiKeyInput!): DisableApiKeyOrErrorPayload!

  createRelease(input: CreateReleaseInput!): CreateReleaseOrErrorPayload!
  makeReleaseLive(input: MakeReleaseLiveInput!): MakeReleaseLiveOrErrorPayload!

  updateNoteGraphPositions(input: UpdateNoteGraphPositionsInput!): UpdateNoteGraphPositionsOrErrorPayload!

  # Telegram bot mutations
  createTgBot(input: CreateTgBotInput!): CreateTgBotOrErrorPayload!
  updateTgBot(input: UpdateTgBotInput!): UpdateTgBotOrErrorPayload!
  addTgChatSubgraphAccess(input: AddTgChatSubgraphAccessInput!): AddTgChatSubgraphAccessOrErrorPayload!
  removeTgChatSubgraphAccess(input: RemoveTgChatSubgraphAccessInput!): RemoveTgChatSubgraphAccessOrErrorPayload!

  # Patreon credentials mutations
  createPatreonCredentials(input: CreatePatreonCredentialsInput!): CreatePatreonCredentialsOrErrorPayload!
  deletePatreonCredentials(input: DeletePatreonCredentialsInput!): DeletePatreonCredentialsOrErrorPayload!
  restorePatreonCredentials(input: RestorePatreonCredentialsInput!): RestorePatreonCredentialsOrErrorPayload!
  refreshPatreonData(input: RefreshPatreonDataInput!): RefreshPatreonDataOrErrorPayload!
}
