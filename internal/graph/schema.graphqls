}

type AdminApiKeyLog @goModel(model: "trip2g/internal/db.ListAPIKeyLogsByAPIKeyIDRow") {
  createdAt: Time!
  actionName: String!
  ip: String!
}

type AdminApiKeyLogsConnection
  @goExtraField(name: "APIKeyID", type: "*int64") {
  nodes: [AdminApiKeyLog!]! @goField(forceResolver: true)
}

type AdminRelease @goModel(model: "trip2g/internal/db.Release") {
