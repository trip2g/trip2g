{
  "meta": {},
  "body": [
    {"type": "html", "html": "<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n  <title>"},
    {"type": "expr", "expr": "note.Title()"},
    {"type": "html", "html": "</title>\n</head>\n<body>\n"},
    {"type": "html", "html": "<header id=\"json-layout-header\">\n  <h1>"},
